DATABASE_HOST=localhost
DATABASE_NAME=sql_website
DATABASE_USER=sql_website
DATABASE_PASSWORD=your_database_password
DATABASE_PORT=3306

BYZIS_HOST=localhost
BYZIS_USER=sql_byzis
BYZIS_PASSWORD=your_byzis_password
BYZIS_NAME=sql_byzis

NODE_ENV=development

NUXT_SESSION_PASSWORD=generate_a_32_character_random_string_here

NUXT_OAUTH_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Midtrans
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
JWT_SECRET_BYZIS=your_jwt_secret_here

API_BASE=/api

DONASI_BASE=https://donasi.baznastangerangkab.or.id

# SIMBA API Config
SIMBA_URL=https://demo-simba.baznas.or.id/
SIMBA_ORG=9977200
SIMBA_KEY=your_simba_api_key_here

# Upload Directory (WAJIB di-set di production!)
# Arahkan ke path absolut DI LUAR .output/ agar tidak terhapus saat build
# Contoh: UPLOAD_DIR=/home/www/baznas/uploads
# Lalu tambahkan di Nginx: location /uploads { alias /home/www/baznas/uploads/; }
# Di development, biarkan kosong (otomatis ke public/uploads/)
UPLOAD_DIR=
